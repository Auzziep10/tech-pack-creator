{
  "expo": {
    "name": "companion-app",
    "slug": "companion-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "buildNumber": "4",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera to capture high-fidelity garment meshes and topography via LiDAR.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for immersive spatial recording during object capture.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiredDeviceCapabilities": [
          "arkit"
        ]
      },
      "bundleIdentifier": "com.auzziep.companionapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "cba7ca1f-3185-4499-8c11-8418f07de719"
      }
    }
  }
}
